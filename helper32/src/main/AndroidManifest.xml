<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permission the main app and the helper use to authenticate to each
         other. Signature-protection-level means only packages signed with
         the same key can hold it. Both APKs are signed with the committed
         debug keystore, so this works deterministically across CI runs. -->
    <permission
        android:name="com.lightbox.ng.permission.HELPER_BRIDGE"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.lightbox.ng.permission.HELPER_BRIDGE" />

    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:name="com.lightbox.app.LightBoxApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/helper_app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LightBox"
        android:enableOnBackInvokedCallback="true"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="n">

        <!-- DELIBERATELY no launcher intent-filter. The helper is headless
             from the user's perspective. All of its activity comes from
             explicit Intents fired by the main app. -->

        <!-- Receives "please launch this virtual app here" requests from main. -->
        <activity
            android:name="com.lightbox.app.helper32.LaunchActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:permission="com.lightbox.ng.permission.HELPER_BRIDGE"
            android:launchMode="singleTask"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="com.lightbox.ng.arm32.action.LAUNCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Install / uninstall requests from main arrive as broadcasts. -->
        <receiver
            android:name="com.lightbox.app.helper32.HelperBridgeReceiver"
            android:exported="true"
            android:permission="com.lightbox.ng.permission.HELPER_BRIDGE">
            <intent-filter>
                <action android:name="com.lightbox.ng.arm32.action.INSTALL" />
                <action android:name="com.lightbox.ng.arm32.action.UNINSTALL" />
            </intent-filter>
        </receiver>

        <!-- ContentProvider so the main app can enumerate the 32-bit games
             installed inside the helper's sandbox (Option A shared library
             view). Main app reads; write-back flows through the broadcast
             receiver above. -->
        <provider
            android:name="com.lightbox.app.helper32.InstalledGamesProvider"
            android:authorities="com.lightbox.ng.arm32.installed_games"
            android:exported="true"
            android:permission="com.lightbox.ng.permission.HELPER_BRIDGE" />
    </application>
</manifest>
